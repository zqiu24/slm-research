# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/
env/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data + checkpoints (NEVER commit)
data/
checkpoints/
*.bin
*.idx
*.safetensors
*.pt
*.ckpt

# W&B local cache
wandb/
*.wandb

# SLURM output
slurm-*.out
*.log

# Resolved-config archive is append-only but can get large; track selectively
runs/**/checkpoints/
runs/**/wandb/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

runs

# Local scratch (node keep-alive loop, etc.)
hold.py
# huawei vendored POET stack — ignore runtime outputs only; the source tree
# is now tracked, so do NOT blanket-ignore the whole directory (that would
# silently drop new files added under it during development).
poet_torch_huawei/runs_dev/
poet_torch_huawei/**/__pycache__/
poet_torch_huawei/**/*.pyc
poet_torch_huawei/**/wandb/
poet_torch_huawei/**/*.log
poet_torch_huawei/training_scripts/**/data_cache/
.claude/

# Reference papers — large PDFs, kept locally only (extract text if needed)
*.pdf

# HTCondor job logs (.out/.err/.log) — keep the dir, ignore the contents
logs/condor/*
!logs/condor/.gitkeep
