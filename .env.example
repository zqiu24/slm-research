# Per-user secrets template. Copy to `.env` (which is gitignored — NEVER commit
# your real keys) and fill in your own values:
#
#   cp .env.example .env && $EDITOR .env
#
# `.env` is sourced automatically at runtime by load_cuda13_2_nccl_env.sh
# (which the venv's activate script and the train_*.sh launchers source), so
# these become environment variables for every run. Do not put real secrets in
# this example file.

# Your personal Weights & Biases API key (W&B → User Settings → API Keys).
# Used to authenticate online logging; without it (and without ~/.netrc) wandb
# runs anonymously or offline.
WANDB_API_KEY=

# Optional W&B overrides (otherwise taken from the Hydra config / cluster):
# WANDB_ENTITY=
# WANDB_PROJECT=
