#!/bin/bash
# Template for the bid clusters (h100_de / a100_de / b200_de).
# Requeue on preemption; SIGTERM trap triggers a final checkpoint save.
#SBATCH --job-name={{ cfg._derived.config_hash }}-s{{ cfg.seed }}
#SBATCH --partition={{ cfg.cluster.slurm_partition }}
#SBATCH --account={{ cfg.cluster.slurm_account }}
#SBATCH --nodes={{ cfg.cluster.nodes }}
#SBATCH --ntasks-per-node={{ cfg.cluster.gpus_per_node }}
#SBATCH --gpus-per-node={{ cfg.cluster.gpus_per_node }}
#SBATCH --cpus-per-task=12
#SBATCH --time=24:00:00
#SBATCH --output=runs/{{ cfg._derived.config_hash }}/slurm-%j.out
#SBATCH --requeue
#SBATCH --signal=B:SIGTERM@120

set -euo pipefail

export WANDB_MODE=offline
export CONFIG_HASH={{ cfg._derived.config_hash }}
export SEED={{ cfg.seed }}

on_preempt() {
    echo "SIGTERM received — flushing checkpoint" >&2
    touch "runs/${CONFIG_HASH}/PREEMPTED.${SLURM_JOB_ID}"
    # Trainer listens for SIGTERM and will flush W&B + save ckpt before exiting.
    kill -TERM $(pgrep -P $$) || true
    wait
}
trap on_preempt SIGTERM

source launchers/env/{{ cfg.cluster.name }}.env

srun python -m launchers.train \
    --config-hash ${CONFIG_HASH} \
    --seed ${SEED} &
wait
